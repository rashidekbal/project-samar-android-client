<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <View
        android:id="@+id/pause_bg"
        android:layout_width="@dimen/dp_45"
        android:layout_height="@dimen/dp_45"
        android:background="@drawable/pause_btn_bg"
        />

        <ProgressBar
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminateTint="@color/white"
            app:layout_constraintTop_toTopOf="@id/pause_bg"
            app:layout_constraintBottom_toBottomOf="@id/pause_bg"
            app:layout_constraintStart_toStartOf="@id/pause_bg"
            app:layout_constraintEnd_toEndOf="@id/pause_bg"

            />


</androidx.constraintlayout.widget.ConstraintLayout>