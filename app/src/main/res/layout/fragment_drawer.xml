<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.Fragment_drawer"
    android:background="@color/surface2"
    android:layout_margin="0dp"
    android:padding="0dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="@dimen/dp_1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_bg"
            android:paddingVertical="@dimen/dp_20"
            android:paddingHorizontal="@dimen/dp_16">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/logo"
                android:layout_width="@dimen/dp_50"
                android:layout_height="@dimen/dp_50"
                app:cardBackgroundColor="@color/accent"
                app:strokeWidth="0dp"
                app:cardCornerRadius="@dimen/radius_medium"
                android:outlineAmbientShadowColor="@color/accent2"
                app:cardElevation="@dimen/dp_16"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="@dimen/dp_60"

                >
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/star"
                    android:layout_gravity="center"
                    android:gravity="center_horizontal"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_24"
                    />
            </com.google.android.material.card.MaterialCardView>
           <LinearLayout
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:orientation="vertical"
               app:layout_constraintStart_toEndOf="@id/logo"
               app:layout_constraintBottom_toBottomOf="@id/logo"
               app:layout_constraintTop_toTopOf="@id/logo"
               android:layout_marginStart="@dimen/dp_16">
               <TextView
                   android:id="@+id/appName"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:text="@string/AppBarName"
                   android:textColor="@color/white"
                   android:textSize="@dimen/sp_19"
                   android:fontFamily="@font/sora"
                   android:textFontWeight="1000"
                   />

               <TextView
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:text="@string/your_best_friend"
                   android:textAlignment="center"
                   android:textColor="#78909C"
                   android:textSize="@dimen/sp_15" />
           </LinearLayout>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchInput_CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/logo"
                app:cardCornerRadius="@dimen/radius_medium"
                android:layout_marginTop="@dimen/dp_25"
                app:strokeWidth="0dp"
                app:cardElevation="@dimen/dp_1"
                app:cardBackgroundColor="@android:color/transparent"


                >
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_45"
                    android:background="@color/surface2"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:id="@+id/search_conv_icon"
                        android:layout_width="@dimen/dp_32"
                        android:layout_height="@dimen/dp_32"
                        android:contentDescription="@string/attachment_icon_desc"
                        android:padding="8dp"
                        android:src="@drawable/search"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:ignore="ImageContrastCheck" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/con_input"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dp_4"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/sora"
                        android:hint="@string/search_conversation"
                        android:minHeight="48dp"
                        android:textColor="@color/text2"
                        android:textColorHint="@color/text2"
                        android:textSize="@dimen/sp_12"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/search_conv_icon"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/new_conversation_card_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/radius_medium"
        android:layout_marginTop="@dimen/dp_25"
        app:strokeWidth="1dp"
        app:strokeColor="@color/accent"
        app:cardElevation="@dimen/dp_1"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginHorizontal="16dp"
        app:rippleColor="@color/accent"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_45"
            android:background="@color/surface3"
            android:paddingHorizontal="10dp">
            <ImageView
                android:id="@+id/add_icon"
                android:layout_width="@dimen/dp_32"
                android:layout_height="@dimen/dp_32"
                android:src="@drawable/plus"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:padding="8dp"
                android:contentDescription="@string/attachment_icon_desc"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_4"
                android:fontFamily="@font/sora"
                android:text="@string/new_conversation"
                android:textColor="@color/accent"
                android:textSize="@dimen/sp_15"
                android:textAlignment="center"
                app:layout_constraintBottom_toBottomOf="@id/add_icon"
                app:layout_constraintStart_toEndOf="@id/add_icon"
                app:layout_constraintTop_toTopOf="@id/add_icon" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/new_conversation_card_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/footer"
        android:paddingHorizontal="@dimen/dp_16"
        android:paddingTop="@dimen/dp_10"
        />
    <androidx.cardview.widget.CardView
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/dp_150"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardElevation="@dimen/dp_1"
        android:paddingVertical="@dimen/dp_10"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/setting_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_medium"
                android:layout_marginTop="@dimen/dp_25"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:layout_constraintTop_toBottomOf="@id/header"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginHorizontal="@dimen/dp_16"
                app:rippleColor="@color/accent"
                >
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_45"
                    android:background="@color/surface3"
                    android:paddingHorizontal="@dimen/dp_10">
                    <ImageView
                        android:id="@+id/setting_icon"
                        android:layout_width="@dimen/dp_45"
                        android:layout_height="@dimen/dp_45"
                        android:src="@drawable/setting"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:padding="8dp"
                        android:contentDescription="@string/attachment_icon_desc"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dp_4"
                        android:fontFamily="@font/sora"
                        android:text="@string/settings"
                        android:textColor="@color/text2"
                        android:textSize="@dimen/sp_15"
                        android:textAlignment="center"
                        app:layout_constraintBottom_toBottomOf="@id/setting_icon"
                        app:layout_constraintStart_toEndOf="@id/setting_icon"
                        app:layout_constraintTop_toTopOf="@id/setting_icon" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/logged_in_user_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_medium"
                android:layout_marginTop="@dimen/dp_15"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:layout_constraintTop_toBottomOf="@id/header"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginHorizontal="@dimen/dp_16"
                app:rippleColor="@color/accent"
                >
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="10dp">
                    <androidx.cardview.widget.CardView
                        android:id="@+id/userInitial_card"
                        android:layout_width="@dimen/dp_40"
                        android:layout_height="@dimen/dp_40"
                        app:cardCornerRadius="@dimen/radius_pill"
                        app:cardBackgroundColor="@color/accent2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/user_intial_char"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/r"
                            android:textColor="@color/white"
                            android:elevation="@dimen/sp_1"
                            android:textAlignment="center"
                            android:layout_gravity="center_vertical"
                            />
                    </androidx.cardview.widget.CardView>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintStart_toEndOf="@id/userInitial_card"
                        app:layout_constraintTop_toTopOf="@id/userInitial_card"
                        app:layout_constraintBottom_toBottomOf="@id/userInitial_card"
                        >
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/dp_4"
                            android:fontFamily="@font/sora"
                            android:text="@string/rashid"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_15"
                            android:textAlignment="center"
                            android:textFontWeight="1000"
                            android:layout_marginStart="@dimen/dp_10"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/dp_4"
                            android:fontFamily="@font/sora"
                            android:text="@string/rasidekbal_dev_samar_app"
                            android:textColor="@color/text2"
                            android:textSize="@dimen/sp_12"
                            android:textAlignment="center"
                            android:textFontWeight="1000"
                            android:layout_marginStart="@dimen/dp_10"/>

                    </LinearLayout>


                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>


    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>